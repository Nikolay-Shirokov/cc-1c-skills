#Область ПрограммныйИнтерфейс
&ИзменениеИКонтроль("Расчёт")
Функция Тест_Расчёт(А, Б)
	Итог = 0.00;
	Итог = А + Б;
	Итог = ОкруглитьВверх(Итог);
	Возврат Итог;
	// [РЕСИНК-КОНФЛИКТ] перенесите блоки ниже вручную — исходный якорь изменился в новой версии оригинала.
	// Материалы для анализа см. в выводе команды (файлы v1/v2/current/diff).
#Вставка
	Итог = 999;
#КонецВставки
КонецФункции
#КонецОбласти
