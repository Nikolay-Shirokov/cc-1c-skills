{
  "name": "Ресинк ИзменениеИКонтроль: изменился якорь вставки (конфликт)",
  "preRun": [
    {
      "script": "meta-compile/scripts/meta-compile",
      "input": { "type": "CommonModule", "name": "РесинкКонфл", "properties": { "Server": true } },
      "args": { "-JsonPath": "{inputFile}", "-OutputDir": "{workDir}" }
    },
    {
      "writeFile": {
        "path": "CommonModules/РесинкКонфл/Ext/Module.bsl",
        "content": "#Область ПрограммныйИнтерфейс\n\nФункция Расчёт(А, Б) Экспорт\n\tИтог = 0.00;\n\tИтог = А + Б;\n\tИтог = ОкруглитьВверх(Итог);\n\tВозврат Итог;\nКонецФункции\n\n#КонецОбласти\n"
      }
    },
    {
      "script": "cfe-init/scripts/cfe-init",
      "args": { "-Name": "Тест", "-OutputDir": "{workDir}/ext", "-ConfigPath": "{workDir}" }
    },
    {
      "script": "cfe-borrow/scripts/cfe-borrow",
      "args": { "-ExtensionPath": "{workDir}/ext", "-ConfigPath": "{workDir}", "-Object": "CommonModule.РесинкКонфл" }
    },
    {
      "writeFile": {
        "path": "ext/CommonModules/РесинкКонфл/Ext/Module.bsl",
        "content": "#Область ПрограммныйИнтерфейс\n&ИзменениеИКонтроль(\"Расчёт\")\nФункция Тест_Расчёт(А, Б)\n\tИтог = 0;\n#Вставка\n\tИтог = 999;\n#КонецВставки\n\tИтог = А + Б;\n\tВозврат Итог;\nКонецФункции\n#КонецОбласти\n"
      }
    }
  ],
  "params": {
    "extensionPath": "ext",
    "modulePath": "CommonModule.РесинкКонфл",
    "methodName": "Расчёт",
    "interceptorType": "ModificationAndControl"
  },
  "expect": { "stdoutContains": "[АКТУАЛИЗИРОВАН-ЧАСТИЧНО]" }
}
