{
  "name": "Перехватчик Вместо для функции (ПродолжитьВызов)",
  "preRun": [
    {
      "script": "meta-compile/scripts/meta-compile",
      "input": { "type": "CommonModule", "name": "ОбщийМодуль2", "properties": { "Server": true } },
      "args": { "-JsonPath": "{inputFile}", "-OutputDir": "{workDir}" }
    },
    {
      "writeFile": {
        "path": "CommonModules/ОбщийМодуль2/Ext/Module.bsl",
        "content": "#Область ПрограммныйИнтерфейс\n\nФункция ПолучитьЗначение(Ключ, ПоУмолчанию = Неопределено) Экспорт\n\tВозврат Ключ;\nКонецФункции\n\n#КонецОбласти\n"
      }
    },
    {
      "script": "cfe-init/scripts/cfe-init",
      "args": { "-Name": "Тест", "-OutputDir": "{workDir}/ext", "-ConfigPath": "{workDir}" }
    },
    {
      "script": "cfe-borrow/scripts/cfe-borrow",
      "args": { "-ExtensionPath": "{workDir}/ext", "-ConfigPath": "{workDir}", "-Object": "CommonModule.ОбщийМодуль2" }
    }
  ],
  "params": {
    "extensionPath": "ext",
    "modulePath": "CommonModule.ОбщийМодуль2",
    "methodName": "ПолучитьЗначение",
    "interceptorType": "Instead"
  },
  "expect": { "stdoutContains": "&Вместо(\"ПолучитьЗначение\")" }
}
