{
  "name": "ModulePath как путь к файлу модуля-источника",
  "preRun": [
    {
      "script": "meta-compile/scripts/meta-compile",
      "input": { "type": "CommonModule", "name": "ФПМодуль", "properties": { "Server": true } },
      "args": { "-JsonPath": "{inputFile}", "-OutputDir": "{workDir}" }
    },
    {
      "writeFile": {
        "path": "CommonModules/ФПМодуль/Ext/Module.bsl",
        "content": "#Область ПрограммныйИнтерфейс\n\nПроцедура ОбработатьДанные(Данные) Экспорт\n\tДанные.Очистить();\nКонецПроцедуры\n\n#КонецОбласти\n"
      }
    },
    {
      "script": "cfe-init/scripts/cfe-init",
      "args": { "-Name": "Тест", "-OutputDir": "{workDir}/ext", "-ConfigPath": "{workDir}" }
    },
    {
      "script": "cfe-borrow/scripts/cfe-borrow",
      "args": { "-ExtensionPath": "{workDir}/ext", "-ConfigPath": "{workDir}", "-Object": "CommonModule.ФПМодуль" }
    }
  ],
  "params": {
    "extensionPath": "ext",
    "modulePath": "CommonModules/ФПМодуль/Ext/Module.bsl",
    "methodName": "ОбработатьДанные",
    "interceptorType": "Before"
  },
  "expect": { "stdoutContains": "&Перед(\"ОбработатьДанные\")" }
}
